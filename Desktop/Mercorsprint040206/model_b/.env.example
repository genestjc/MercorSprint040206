# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SESSION_SECRET=                  # random 32+ chars; signs the member JWT cookie
ADMIN_SECRET=                    # required to use /uploads + POST /api/videos

# --- ThirdWeb (embedded wallet + on-chain membership on Base, 8453) ---
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
BACKEND_WALLET_PK=               # owner of MembershipPass; funds gas on Base
NEXT_PUBLIC_MEMBERSHIP_CONTRACT=

# --- Stripe (recurring subscription) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Mux (upload + signed playback) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=              # Settings → Signing Keys
MUX_SIGNING_KEY_SECRET=          # base64 private key from the same screen
